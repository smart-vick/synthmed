# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email Service (Gmail with App Password)
# https://support.google.com/accounts/answer/185833
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-16-character-app-password

# Admin Key (for /api/v1/admin/* endpoints)
ADMIN_KEY=your-secure-admin-key-change-in-production

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Database (default: synthmed.db in root)
DATABASE_URL=

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_API_KEYS=true
ENABLE_USAGE_TRACKING=true
